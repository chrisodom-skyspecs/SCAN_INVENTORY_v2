# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example
#
# Copy this file to .env.local and fill in your actual values.
# See docs/kinde-setup.md for complete setup instructions.
#
# SECURITY: Never commit .env.local with real secrets to version control.
# All Kinde, FedEx, and Convex server-side vars are server-only — no
# NEXT_PUBLIC_ prefix — and must never be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Kinde Authentication ─────────────────────────────────────────────────────
#
# Single "Back-end web" Kinde application serving both INVENTORY (/inventory)
# and SCAN (/scan) from this Next.js deployment.
#
# Setup: docs/kinde-setup.md — Steps 1–3
# Source: https://app.kinde.com → Applications → [skyspecs app] → App keys
#
# ── Kinde Dashboard: Application → Authentication ────────────────────────────
#
# Application type: Back-end web
#
# Allowed callback URLs (OAuth redirect URIs):
#   http://localhost:3000/api/auth/kinde_callback          (development)
#   https://inventory.skyspecsops.com/api/auth/kinde_callback   (production)
#   https://skyspecs-inventory.vercel.app/api/auth/kinde_callback  (Vercel)
#
# Allowed logout redirect URLs:
#   http://localhost:3000                                   (dev — INVENTORY)
#   http://localhost:3000/scan                              (dev — SCAN landing)
#   http://localhost:3000/scan/login                        (dev — SCAN login)
#   https://inventory.skyspecsops.com                      (prod — INVENTORY)
#   https://inventory.skyspecsops.com/scan                 (prod — SCAN landing)
#   https://inventory.skyspecsops.com/scan/login           (prod — SCAN login)
#   https://skyspecs-inventory.vercel.app                  (Vercel preview)
#   https://skyspecs-inventory.vercel.app/scan             (Vercel preview SCAN)
#   https://skyspecs-inventory.vercel.app/scan/login       (Vercel preview SCAN)
#
# Allowed origins (CORS):
#   http://localhost:3000
#   https://inventory.skyspecsops.com
#
# ─────────────────────────────────────────────────────────────────────────────

# Required: Kinde application Client ID
# (Kinde dashboard → Applications → [your app] → App keys → Client ID)
KINDE_CLIENT_ID=your_kinde_client_id_here

# Required: Kinde application Client Secret
# (Kinde dashboard → Applications → [your app] → App keys → Client Secret)
KINDE_CLIENT_SECRET=your_kinde_client_secret_here

# Required: Kinde issuer / domain URL (format: https://<subdomain>.kinde.com)
# (Kinde dashboard → Settings → Domain)
KINDE_ISSUER_URL=https://your-org.kinde.com

# Required: Base URL of this application (no trailing slash)
# Development: http://localhost:3000
# Production:  https://inventory.skyspecsops.com
KINDE_SITE_URL=http://localhost:3000

# Required: Where to redirect after logout (both INVENTORY and SCAN users
# land at the root, which redirects to the appropriate app)
# Development: http://localhost:3000
# Production:  https://inventory.skyspecsops.com
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000

# Required: Default post-login redirect for INVENTORY dashboard users.
# SCAN users are redirected back to their SCAN URL automatically by the
# withAuth middleware via the post_login_redirect_url query parameter.
# Development: http://localhost:3000/inventory
# Production:  https://inventory.skyspecsops.com/inventory
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/inventory

# Security: Regex for valid post-login redirect URLs (open-redirect guard).
# Allows any path under /inventory or /scan on the known origins.
KINDE_POST_LOGIN_ALLOWED_URL_REGEX=^(http://localhost:3000|https://inventory\.skyspecsops\.com)/(inventory|scan)(/.*)?$

# SCAN-specific redirect — fallback destination for the SCAN login flow when
# no deeper URL is available from the middleware.
# Development: http://localhost:3000/scan
# Production:  https://inventory.skyspecsops.com/scan
KINDE_SCAN_POST_LOGIN_REDIRECT_URL=http://localhost:3000/scan

# Kinde Management API (Machine-to-Machine application — optional)
# Used for server-side Kinde Management API calls (user listing, role assignment).
# Setup: docs/kinde-setup.md — Step 4
# (Kinde dashboard → Applications → [management app] → App keys)
KINDE_MANAGEMENT_CLIENT_ID=your_kinde_management_client_id_here
KINDE_MANAGEMENT_CLIENT_SECRET=your_kinde_management_client_secret_here

# ─── FedEx Tracking API ──────────────────────────────────────────────────────
# Obtain credentials from https://developer.fedex.com/api/en-us/home.html
# Server-side only — never expose to the browser (no NEXT_PUBLIC_ prefix).

# Required: OAuth 2.0 client credentials from the FedEx Developer Portal
FEDEX_CLIENT_ID=your_fedex_client_id_here
FEDEX_CLIENT_SECRET=your_fedex_client_secret_here

# Optional: FedEx account number for enhanced tracking detail
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number_here

# Optional: Override base URL to use FedEx sandbox for development/testing
# Leave unset (or commented out) to use the production API.
# FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com
FEDEX_API_BASE_URL=https://apis.fedex.com

# ─── Convex ───────────────────────────────────────────────────────────────────
# Obtain from: https://dashboard.convex.dev → [your project] → Settings → URL & Deploy Key
# Development deployment URL (npx convex dev):
NEXT_PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud

# Development Convex site URL (HTTP Actions):
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-dev-deployment.convex.site

# Convex deployment identifier (set by `npx convex dev`):
CONVEX_DEPLOYMENT=dev:your-dev-deployment-name

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Obtain from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ─── SCAN App ─────────────────────────────────────────────────────────────────
# Base URL of the SCAN mobile app (used for QR code generation and deep links).
# Development: http://localhost:3000/scan
# Production:  https://inventory.skyspecsops.com/scan
NEXT_PUBLIC_SCAN_APP_URL=http://localhost:3000/scan

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "1" or "true" to enable. Leave unset or set to "0" to disable.
NEXT_PUBLIC_FF_MAP_MISSION=0
NEXT_PUBLIC_FF_AUDIT_HASH_CHAIN=0
NEXT_PUBLIC_FF_INV_REDESIGN=0
